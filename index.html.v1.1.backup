<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Vibe Air Guitar</title>
  <link rel="stylesheet" href="./styles.css?v=13">
</head>
<body>
  <main class="app">
    <section class="stage">
      <div class="video-wrap fx-off">
        <video id="camera" autoplay muted playsinline></video>
        <div class="camera-fallback" id="cameraFallback">开启摄像头，摆 1-5 号手势开弹</div>
        <canvas id="handCanvas" aria-hidden="true"></canvas>
        <canvas id="faceCanvas" aria-hidden="true"></canvas>
        <div class="effects-layer" id="effectsLayer" aria-hidden="true"></div>
        <div class="gesture-badge">
          <span id="gestureName">未选择手势</span>
          <strong id="activeChord">--</strong>
          <em id="detectStatus">手势识别未启动</em>
        </div>
        <div class="lyrics-overlay" id="lyricsOverlay"></div>
        <div class="live-gesture-palette" id="liveGesturePalette"></div>
        <div class="beat-meter" id="beatMeter"></div>
      </div>
    </section>

    <aside class="controls">
      <header>
        <p>本地浏览器版</p>
        <h1>Vibe Air Guitar</h1>
      </header>

      <div class="panel">
        <div class="row">
          <button id="cameraBtn" class="secondary">开启摄像头识别</button>
          <button id="playBtn">开始伴奏</button>
        </div>
        <div class="row">
          <button id="autoBtn" class="secondary active">自动保持和弦</button>
          <button id="themeBtn" class="secondary">白色玻璃</button>
        </div>
        <label>
          BPM
          <input id="bpm" type="range" min="60" max="140" value="92">
          <span id="bpmValue">92</span>
        </label>
        <label>
          调性
          <select id="keySelect">
            <option value="C">C</option>
            <option value="D">D</option>
            <option value="E">E</option>
            <option value="F">F</option>
            <option value="G">G</option>
            <option value="A">A</option>
            <option value="B">B</option>
          </select>
          <span id="keyLabel">C调</span>
        </label>
        <label>
          音色
          <select id="instrumentSelect">
            <option value="guitar">吉他</option>
            <option value="electric">电吉他</option>
            <option value="piano">钢琴</option>
            <option value="tinbox">半岛铁盒</option>
            <option value="musicbox">八音盒</option>
            <option value="glassbell">玻璃铃</option>
            <option value="celeste">星光琴</option>
            <option value="softpad">柔光电钢</option>
            <option value="mallet">木槌琴</option>
          </select>
          <span id="sampleStatus">采样</span>
        </label>
        <label>
          Capo
          <input id="capo" type="range" min="0" max="5" value="0">
          <span id="capoValue">0</span>
        </label>
        <div class="row tinbox-row" id="tinboxMelodyRow">
          <button id="tinboxMelodyBtn" class="secondary active">半岛旋律 53231323</button>
          <span id="tinboxMelodyStatus">半岛系音色生效</span>
        </div>
      </div>

      <div class="panel">
        <h2>和弦谱</h2>
        <textarea id="progressionInput" rows="2">C G Am F</textarea>
        <div class="progression-strip" id="progressionStrip"></div>
        <p class="hint">输入真实和弦名，系统会反查应该摆几号国际数字手势。</p>
      </div>

      <div class="panel">
        <h2>上传和弦图识别</h2>
        <input id="chordImageUpload" type="file" accept="image/*">
        <p class="hint" id="chordImageStatus">上传截图后自动识别和弦，并按顺序设置到 1-5。</p>
      </div>

      <div class="panel">
        <h2>上传谱子演奏</h2>
        <input id="scoreImageUpload" type="file" accept="image/*">
        <div class="row">
          <button id="scorePlayBtn" class="secondary" disabled>谱子模式</button>
          <button id="scoreClearBtn" class="secondary" disabled>清除谱子</button>
        </div>
        <p class="hint" id="scoreImageStatus">上传谱子后识别和弦、拍速、调性和简谱数字。</p>
      </div>

      <div class="panel">
        <h2>节奏型</h2>
        <select id="rhythmSelect"></select>
        <div class="toggle-list">
          <label><input id="drumToggle" type="checkbox" checked> 鼓开关</label>
          <label><input id="muteToggle" type="checkbox"> 闷音 x</label>
          <label><input id="spreadToggle" type="checkbox" checked> 扫弦 spread</label>
          <label><input id="randomToggle" type="checkbox" checked> 力度随机</label>
        </div>
      </div>

      <div class="panel">
        <h2>上传节奏音频</h2>
        <input id="rhythmUpload" type="file" accept="audio/*">
        <div class="row">
          <button id="rhythmBtn" class="secondary" disabled>播放上传节奏</button>
          <button id="clearRhythmBtn" class="secondary" disabled>清除音频</button>
        </div>
        <audio id="rhythmAudio" loop></audio>
        <p class="hint" id="rhythmStatus">支持 mp3、wav、m4a；上传后作为循环节奏底。</p>
      </div>

      <div class="panel">
        <h2>演奏方式</h2>
        <div class="segmented" id="patternButtons"></div>
        <div id="customMelodySection" style="display:none;margin-top:8px">
          <p class="hint">编辑自定义走向：先录入，再保存，循环时自动套用根音换算。</p>
          <div class="row" id="customStringButtons" style="display:flex;gap:4px;flex-wrap:wrap;margin:6px 0"></div>
          <div class="row" style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin:4px 0">
            <span id="customProgressionDisplay" style="font-family:monospace;font-size:13px;color:#aaa">5 · 3 · 2 · 3 · 1 · 3 · 2 · 3</span>
            <button id="customEditBtn" class="secondary" style="padding:2px 8px;font-size:12px">编辑</button>
            <button id="customSaveBtn" class="secondary" style="padding:2px 8px;font-size:12px">保存</button>
            <button id="customClearBtn" class="secondary" style="padding:2px 8px;font-size:12px">清空</button>
          </div>
          <p class="hint" id="customMelodyHint">选择“自定义”演奏方式后，任何音色都可用自定义走向，根音弦自动随和弦变化。</p>
        </div>
      </div>

      <div class="panel">
        <h2>国际数字手势 1-5</h2>
        <div class="gesture-grid" id="gestureButtons"></div>
        <button id="clearCustomAudioBtn" class="secondary danger full-width">一键清除上传音频和绑定</button>
      </div>

      <div class="panel compact">
        <h2>当前手势绑定</h2>
        <p id="mappingText">1 C · 2 D · 3 E · 4 F · 5 G</p>
        <p>手在镜头里才响；只识别 1-5，减少误触发。音色选半岛系乐器时，C/D/E 等和弦会持续响到手势放下；上传音频后优先播放自定义音频。</p>
      </div>
    </aside>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils/drawing_utils.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/face_detection/face_detection.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
  <script src="./loop-module.js?v=4"></script>
  <script src="./app.js?v=17"></script>
</body>
</html>
