:root {
  color-scheme: dark;
  font-family: Inter, "PingFang SC", "Microsoft YaHei", sans-serif;
  --page-bg:
    radial-gradient(circle at 16% 12%, rgba(255, 255, 255, 0.18), transparent 26%),
    radial-gradient(circle at 82% 18%, rgba(139, 211, 221, 0.22), transparent 30%),
    linear-gradient(135deg, #08090b 0%, #17191e 48%, #060708 100%);
  --text: #f7f7f5;
  --muted: rgba(247,247,245,0.68);
  --glass: rgba(255,255,255,0.1);
  --glass-strong: rgba(255,255,255,0.16);
  --stroke: rgba(255,255,255,0.18);
  --button: rgba(255,255,255,0.16);
  --button-text: #f7f7f5;
  --accent: #ffd166;
  --accent-2: #8bd3dd;
  background: #08090b;
  color: var(--text);
}

* { box-sizing: border-box; }

body {
  margin: 0;
  min-height: 100vh;
  overflow: hidden;
  color: var(--text);
  background: var(--page-bg);
}

body[data-theme="light"] {
  color-scheme: light;
  --page-bg:
    radial-gradient(circle at 12% 10%, rgba(255,255,255,0.92), transparent 30%),
    radial-gradient(circle at 84% 18%, rgba(187, 221, 255, 0.58), transparent 32%),
    linear-gradient(135deg, #eef0f5 0%, #f8f8f4 48%, #dde5ee 100%);
  --text: #15171b;
  --muted: rgba(21,23,27,0.64);
  --glass: rgba(255,255,255,0.48);
  --glass-strong: rgba(255,255,255,0.66);
  --stroke: rgba(255,255,255,0.72);
  --button: rgba(255,255,255,0.58);
  --button-text: #15171b;
  --accent: #0aa66a;
  --accent-2: #2c72d8;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
  background-size: 42px 42px;
  mask-image: linear-gradient(to bottom, rgba(0,0,0,0.72), transparent 72%);
}

button, input, select { font: inherit; }

.app {
  height: 100vh;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 360px);
  gap: 18px;
  padding: 18px;
  overflow: hidden;
}

.stage {
  min-width: 0;
  display: grid;
}

.video-wrap {
  position: relative;
  overflow: hidden;
  border: 1px solid var(--stroke);
  border-radius: 8px;
  background: rgba(255,255,255,0.08);
  box-shadow: 0 24px 70px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.18);
  backdrop-filter: blur(24px) saturate(1.35);
  height: calc(100vh - 36px);
  min-height: 0;
}

video {
  width: 100%;
  height: 100%;
  min-height: 0;
  object-fit: cover;
  transform: scaleX(-1);
  opacity: 0.84;
  filter: saturate(1.05) contrast(1.05);
}

#handCanvas,
#faceCanvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  transform: scaleX(-1);
  pointer-events: none;
}

#faceCanvas {
  z-index: 4;
}

#handCanvas {
  z-index: 3;
}

.camera-fallback {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  color: rgba(243, 240, 232, 0.72);
  background: repeating-linear-gradient(135deg, #111 0 18px, #151915 18px 36px);
}

.camera-fallback.hidden { display: none; }

.gesture-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  display: grid;
  gap: 2px;
  min-width: 126px;
  padding: 10px 12px;
  border-radius: 8px;
  background: var(--glass-strong);
  border: 1px solid var(--stroke);
  box-shadow: 0 10px 28px rgba(0,0,0,0.24);
  backdrop-filter: blur(22px) saturate(1.4);
  text-align: left;
  z-index: 7;
}

.gesture-badge span {
  font-size: 12px;
  color: rgba(243,240,232,0.68);
}

.gesture-badge strong {
  font-size: 36px;
  line-height: 1;
  color: #ffd166;
}

.gesture-badge em {
  max-width: 220px;
  color: rgba(243,240,232,0.62);
  font-size: 11px;
  font-style: normal;
  line-height: 1.35;
}

.gesture-ring {
  display: none;
  position: absolute;
  left: 50%;
  top: 50%;
  width: min(68vw, 620px);
  aspect-ratio: 1;
  transform: translate(-50%, -44%);
  border-radius: 50%;
  pointer-events: none;
  border: 3px solid rgba(255, 209, 102, 0.5);
  box-shadow:
    inset 0 0 28px rgba(36, 231, 120, 0.28),
    0 0 0 6px rgba(139, 211, 221, 0.16),
    0 0 42px rgba(255, 209, 102, 0.26);
  z-index: 3;
  animation: ringPulse 1.5s ease-in-out infinite;
}

.video-wrap.fx-off #faceCanvas,
.video-wrap.fx-off .effects-layer {
  display: none;
}

.effects-layer {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 4;
}

.fx-pop {
  position: absolute;
  display: grid;
  place-items: center;
  min-width: 28px;
  height: 28px;
  font-size: clamp(18px, 3.2vw, 36px);
  font-weight: 900;
  text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  animation: fxPop 900ms ease-out forwards;
}

.lyrics-overlay {
  position: absolute;
  left: 50%;
  bottom: 178px;
  width: min(760px, calc(100% - 48px));
  transform: translateX(-50%);
  padding: 10px 14px;
  border-radius: 8px;
  background: var(--glass);
  backdrop-filter: blur(24px) saturate(1.4);
  text-align: center;
  border: 1px solid var(--stroke);
}

.live-gesture-palette {
  position: absolute;
  left: 50%;
  bottom: 76px;
  width: min(760px, calc(100% - 48px));
  transform: translateX(-50%);
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 10px;
  z-index: 6;
}

.live-gesture-palette button {
  display: grid;
  place-items: center;
  gap: 2px;
  min-height: 66px;
  padding: 8px;
  color: var(--button-text);
  background: var(--button);
  border: 1px solid var(--stroke);
  backdrop-filter: blur(22px) saturate(1.35);
}

.live-gesture-palette button.active {
  color: #06251a;
  background: #24e778;
  border-color: rgba(255,255,255,0.5);
  outline: 0;
  box-shadow: 0 0 28px rgba(36, 231, 120, 0.42);
}

.live-gesture-palette strong {
  font-size: clamp(16px, 2.1vw, 28px);
  line-height: 1;
}

.live-gesture-palette span {
  font-size: 13px;
  opacity: 0.72;
}

.beat-meter {
  position: absolute;
  left: 50%;
  bottom: 42px;
  width: min(760px, calc(100% - 48px));
  transform: translateX(-50%);
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 6px;
  z-index: 6;
}

.beat-meter i {
  height: 5px;
  border-radius: 999px;
  background: rgba(255,255,255,0.22);
}

.beat-meter i.active {
  background: #ffd166;
  box-shadow: 0 0 18px rgba(255, 209, 102, 0.82);
}

.lyric-line {
  margin: 0;
  font-size: clamp(18px, 2.2vw, 28px);
  line-height: 1.18;
  font-weight: 700;
}

.lyric-meta {
  margin-top: 8px;
  display: flex;
  justify-content: center;
  gap: 12px;
  color: var(--muted);
}

.lyric-chord {
  color: var(--accent-2);
  font-weight: 800;
}

.controls {
  display: flex;
  flex-direction: column;
  gap: 14px;
  min-height: 0;
  overflow: auto;
  padding-right: 4px;
}

header p {
  margin: 0 0 4px;
  color: var(--accent-2);
  font-size: 12px;
}

header {
  position: sticky;
  top: 0;
  z-index: 2;
  padding: 2px 0 4px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.08), rgba(255,255,255,0));
}

h1, h2 {
  margin: 0;
  letter-spacing: 0;
}

h1 { font-size: 26px; }
h2 { font-size: 15px; }

.panel {
  display: grid;
  gap: 12px;
  padding: 14px;
  border: 1px solid var(--stroke);
  border-radius: 8px;
  background: var(--glass);
  box-shadow: 0 14px 34px rgba(0,0,0,0.16), inset 0 1px 0 rgba(255,255,255,0.18);
  backdrop-filter: blur(24px) saturate(1.35);
}

.panel.compact p {
  margin: 0;
  color: rgba(243,240,232,0.72);
  line-height: 1.5;
  font-size: 13px;
}

.row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.tinbox-row {
  align-items: center;
}

.tinbox-row.hidden {
  display: none;
}

.tinbox-row span {
  min-height: 42px;
  display: grid;
  align-items: center;
  padding: 0 10px;
  border-radius: 7px;
  color: var(--muted);
  background: var(--glass);
  border: 1px solid var(--stroke);
  font-size: 12px;
}

button {
  border: 0;
  border-radius: 7px;
  min-height: 42px;
  padding: 0 12px;
  color: #15171b;
  background: var(--accent);
  cursor: pointer;
  font-weight: 800;
}

button.secondary {
  color: var(--button-text);
  background: var(--button);
  border: 1px solid var(--stroke);
  backdrop-filter: blur(18px) saturate(1.3);
}

button.active {
  outline: 2px solid var(--accent-2);
}

button:disabled {
  cursor: not-allowed;
  opacity: 0.45;
}

label {
  display: grid;
  grid-template-columns: auto minmax(0,1fr) 36px;
  align-items: center;
  gap: 10px;
  color: var(--muted);
}

.toggle-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.toggle-list label {
  grid-template-columns: 18px minmax(0, 1fr);
  min-height: 34px;
  padding: 7px 8px;
  border-radius: 7px;
  background: var(--glass);
  font-size: 13px;
}

input[type="range"] { width: 100%; }
select, textarea {
  min-height: 34px;
  border: 1px solid var(--stroke);
  border-radius: 7px;
  color: var(--text);
  background: var(--glass-strong);
  backdrop-filter: blur(14px);
}

textarea {
  width: 100%;
  resize: vertical;
  padding: 9px 10px;
  line-height: 1.45;
}

.progression-strip {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 2px;
}

.progression-strip span {
  flex: 0 0 auto;
  min-width: 72px;
  display: grid;
  gap: 2px;
  padding: 8px 10px;
  border-radius: 7px;
  background: var(--glass);
  border: 1px solid var(--stroke);
}

.progression-strip span.active {
  border-color: var(--accent-2);
  background: rgba(139, 211, 221, 0.16);
}

.progression-strip strong,
.progression-strip em,
.progression-strip small {
  font-style: normal;
  line-height: 1.15;
}

.progression-strip em,
.progression-strip small {
  color: var(--muted);
  font-size: 11px;
}
input[type="file"] {
  width: 100%;
  color: var(--muted);
}

audio {
  width: 100%;
  height: 34px;
}

.hint {
  margin: 0;
  color: var(--muted);
  font-size: 12px;
  line-height: 1.45;
}

.segmented, .gesture-grid {
  display: grid;
  gap: 8px;
}

.gesture-grid {
  grid-template-columns: 1fr;
}

.gesture-card {
  display: grid;
  grid-template-columns: 42px minmax(0, 1fr) minmax(116px, 138px);
  align-items: center;
  gap: 10px;
  min-height: 72px;
  padding: 10px;
  border-radius: 8px;
  border: 1px solid var(--stroke);
  background: var(--glass);
  backdrop-filter: blur(18px) saturate(1.3);
}

.gesture-card.active {
  border-color: var(--accent-2);
  background: rgba(139, 211, 221, 0.16);
}

.gesture-card button {
  min-height: 42px;
  width: 42px;
  padding: 0;
}

.gesture-copy {
  display: grid;
  gap: 3px;
}

.gesture-copy strong {
  font-size: 14px;
}

.gesture-copy small {
  color: var(--muted);
  line-height: 1.25;
}

.gesture-edit {
  display: grid;
  gap: 6px;
}

.gesture-card select {
  width: 100%;
}

.chord-upload {
  display: block;
  position: relative;
  overflow: hidden;
}

.chord-upload input {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
}

.chord-upload span {
  display: block;
  width: 100%;
  min-height: 32px;
  padding: 7px 8px;
  border-radius: 7px;
  border: 1px solid var(--stroke);
  background: var(--glass);
  color: var(--text);
  font-size: 12px;
  font-weight: 700;
  text-align: center;
}

.full-width {
  width: 100%;
  margin-top: 10px;
}

.danger {
  border-color: rgba(255, 118, 96, 0.45);
  color: #ffd8d0;
}

.gesture-grid small {
  font-size: 12px;
  font-weight: 600;
  opacity: 0.72;
}

@media (max-width: 860px) {
  body {
    overflow: auto;
  }

  .app {
    height: auto;
    min-height: 100vh;
    grid-template-columns: 1fr;
    padding: 12px;
    overflow: visible;
  }

  .video-wrap, video {
    height: clamp(260px, 48vh, 420px);
    min-height: 0;
  }

  .lyrics-overlay {
    bottom: 124px;
    width: calc(100% - 24px);
    padding: 10px 12px;
  }

  .lyric-line {
    font-size: 22px;
  }

  .gesture-badge {
    top: 10px;
    left: 10px;
  }

  .gesture-badge strong {
    font-size: 34px;
  }

  .gesture-ring {
    width: min(92vw, 430px);
  }

  .live-gesture-palette {
    bottom: 46px;
    width: calc(100% - 24px);
    gap: 5px;
  }

  .live-gesture-palette button {
    min-height: 48px;
    padding: 6px 4px;
  }

  .beat-meter {
    bottom: 24px;
    width: calc(100% - 24px);
  }

  .controls {
    overflow: visible;
    padding-right: 0;
  }

  .controls {
    padding-bottom: 16px;
  }
}

@keyframes ringPulse {
  0%, 100% { opacity: 0.75; transform: translate(-50%, -44%) scale(0.98); }
  50% { opacity: 1; transform: translate(-50%, -44%) scale(1.02); }
}

@keyframes fxPop {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.45) rotate(0);
  }
  16% { opacity: 1; }
  100% {
    opacity: 0;
    transform: translate(calc(-50% + var(--dx)), calc(-50% + var(--dy))) scale(1.25) rotate(var(--rot));
  }
}

/* ========= Loop Module ========= */
.loop-module {
  margin: 18px 0 24px;
  padding: 16px 18px 20px;
  border: 1px solid rgba(140, 170, 200, 0.28);
  border-radius: 14px;
  background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(244,249,255,0.86));
  box-shadow: 0 8px 24px rgba(33, 71, 110, 0.08);
  display: grid;
  gap: 12px;
}
.loop-module-head h2 {
  margin: 0 0 4px;
  font-size: 16px;
  letter-spacing: 0.04em;
}
.loop-module-hint {
  margin: 0;
  font-size: 12px;
  color: #6b7d8c;
  line-height: 1.5;
}
.loop-module-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
}
.loop-module-label {
  flex: 0 0 auto;
  min-width: 88px;
  font-size: 12px;
  font-weight: 600;
  color: #44607a;
  letter-spacing: 0.06em;
}
.loop-module-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.loop-btn {
  padding: 6px 12px;
  font-size: 13px;
  border-radius: 999px;
  border: 1px solid rgba(80, 130, 180, 0.35);
  background: #fff;
  color: #2c4a66;
  cursor: pointer;
  transition: transform 0.08s ease, background 0.2s ease, color 0.2s ease;
}
.loop-btn:hover { transform: translateY(-1px); }
.loop-btn.active {
  background: linear-gradient(180deg, #4a90e2, #2f6fbe);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4px 12px rgba(74, 144, 226, 0.35);
}
.loop-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.loop-btn-primary {
  background: linear-gradient(180deg, #ff9f6e, #ff7a45);
  color: #fff;
  border-color: transparent;
}
.loop-btn-primary.active {
  background: linear-gradient(180deg, #ff7a45, #d8501c);
  box-shadow: 0 4px 14px rgba(255, 122, 69, 0.4);
}
.loop-btn-danger {
  border-color: rgba(220, 80, 90, 0.5);
  color: #c0414c;
}
.loop-select {
  padding: 6px 10px;
  border-radius: 8px;
  border: 1px solid rgba(80, 130, 180, 0.35);
  background: #fff;
  font-size: 13px;
  color: #2c4a66;
  min-width: 140px;
}
.loop-module-strings {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.loop-string-btn {
  position: relative;
  width: 60px;
  height: 60px;
  border-radius: 12px;
  border: 1px solid rgba(80, 130, 180, 0.35);
  background: linear-gradient(180deg, #ffffff, #eef5ff);
  display: grid;
  align-content: center;
  justify-items: center;
  gap: 2px;
  cursor: pointer;
  transition: transform 0.08s ease, box-shadow 0.2s ease, background 0.15s ease;
  user-select: none;
}
.loop-string-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 14px rgba(33, 71, 110, 0.12);
}
.loop-string-btn.flash {
  background: linear-gradient(180deg, #ffd9b3, #ff9f6e);
  color: #fff;
}
.loop-string-num {
  font-size: 22px;
  font-weight: 700;
  color: #2c4a66;
}
.loop-string-btn.flash .loop-string-num { color: #fff; }
.loop-string-tag {
  font-size: 11px;
  color: #6b7d8c;
  letter-spacing: 0.1em;
}
.loop-module.loop-module-editing #loopEditStrings .loop-string-btn {
  border-color: #ff7a45;
  box-shadow: 0 0 0 2px rgba(255, 122, 69, 0.18);
}
.loop-progression {
  flex: 1 1 auto;
  padding: 8px 12px;
  border-radius: 10px;
  background: rgba(20, 60, 100, 0.06);
  font-family: ui-monospace, "JetBrains Mono", "SF Mono", monospace;
  font-size: 14px;
  color: #2c4a66;
  letter-spacing: 0.18em;
  min-height: 18px;
}
.loop-module-controls .loop-btn { padding: 8px 14px; font-size: 13px; }
.loop-module-status {
  margin: 4px 0 0;
  font-size: 12px;
  color: #5a7286;
  font-style: italic;
}
#loopBpm {
  flex: 1 1 200px;
  max-width: 280px;
}
@media (max-width: 640px) {
  .loop-module-label { min-width: 100%; }
  .loop-string-btn { width: 48px; height: 48px; }
  .loop-string-num { font-size: 18px; }
}

/* ===== Loop module: root-adaptive toggle & progression display ===== */
.loop-toggle {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: #44607a;
  cursor: pointer;
  user-select: none;
}
.loop-toggle input[type="checkbox"] {
  accent-color: #4a90e2;
  margin: 0;
}
.loop-prog-raw {
  color: #6b7d8c;
  letter-spacing: 0.18em;
}
.loop-prog-arrow {
  margin: 0 4px;
  color: #4a90e2;
  font-weight: 600;
}
.loop-prog-real {
  color: #2c4a66;
  font-weight: 700;
  letter-spacing: 0.18em;
}
.loop-prog-tag {
  margin-left: 6px;
  padding: 2px 8px;
  border-radius: 999px;
  background: rgba(74, 144, 226, 0.18);
  color: #2c4a66;
  font-size: 12px;
  letter-spacing: 0.04em;
}
