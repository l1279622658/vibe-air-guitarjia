:root {
  color-scheme: dark;
  font-family: Inter, "PingFang SC", "Microsoft YaHei", sans-serif;
  --page-bg:
    radial-gradient(circle at 16% 12%, rgba(255, 255, 255, 0.18), transparent 26%),
    radial-gradient(circle at 82% 18%, rgba(139, 211, 221, 0.22), transparent 30%),
    linear-gradient(135deg, #08090b 0%, #17191e 48%, #060708 100%);
  --text: #f7f7f5;
  --muted: rgba(247,247,245,0.68);
  --glass: rgba(255,255,255,0.1);
  --glass-strong: rgba(255,255,255,0.16);
  --stroke: rgba(255,255,255,0.18);
  --button: rgba(255,255,255,0.16);
  --button-text: #f7f7f5;
  --accent: #ffd166;
  --accent-2: #8bd3dd;
  background: #08090b;
  color: var(--text);
}

* { box-sizing: border-box; }

body {
  margin: 0;
  min-height: 100vh;
  overflow: hidden;
  color: var(--text);
  background: var(--page-bg);
}

body[data-theme="light"] {
  color-scheme: light;
  --page-bg:
    radial-gradient(circle at 12% 10%, rgba(255,255,255,0.92), transparent 30%),
    radial-gradient(circle at 84% 18%, rgba(187, 221, 255, 0.58), transparent 32%),
    linear-gradient(135deg, #eef0f5 0%, #f8f8f4 48%, #dde5ee 100%);
  --text: #15171b;
  --muted: rgba(21,23,27,0.64);
  --glass: rgba(255,255,255,0.48);
  --glass-strong: rgba(255,255,255,0.66);
  --stroke: rgba(255,255,255,0.72);
  --button: rgba(255,255,255,0.58);
  --button-text: #15171b;
  --accent: #0aa66a;
  --accent-2: #2c72d8;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
  background-size: 42px 42px;
  mask-image: linear-gradient(to bottom, rgba(0,0,0,0.72), transparent 72%);
}

button, input, select { font: inherit; }

.app {
  height: 100vh;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 360px);
  gap: 18px;
  padding: 18px;
  overflow: hidden;
}

.stage {
  min-width: 0;
  display: grid;
}

.video-wrap {
  position: relative;
  overflow: hidden;
  border: 1px solid var(--stroke);
  border-radius: 12px;
  background: rgba(255,255,255,0.08);
  box-shadow: 0 24px 70px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.18);
  backdrop-filter: blur(30px) saturate(1.42);
  height: calc(100vh - 36px);
  min-height: 0;
}

video {
  width: 100%;
  height: 100%;
  min-height: 0;
  object-fit: cover;
  transform: scaleX(-1);
  opacity: 0.84;
  filter: saturate(1.05) contrast(1.05);
}

#handCanvas,
#faceCanvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  transform: scaleX(-1);
  pointer-events: none;
}

#faceCanvas {
  z-index: 4;
}

#handCanvas {
  z-index: 3;
}

.camera-fallback {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  color: rgba(243, 240, 232, 0.72);
  background: repeating-linear-gradient(135deg, #111 0 18px, #151915 18px 36px);
}

.camera-fallback.hidden { display: none; }

.gesture-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  display: grid;
  gap: 2px;
  min-width: 126px;
  padding: 10px 12px;
  border-radius: 8px;
  background: var(--glass-strong);
  border: 1px solid var(--stroke);
  box-shadow: 0 10px 28px rgba(0,0,0,0.24);
  backdrop-filter: blur(22px) saturate(1.4);
  text-align: left;
  z-index: 7;
}

.gesture-badge span {
  font-size: 12px;
  color: rgba(243,240,232,0.68);
}

.gesture-badge strong {
  font-size: 36px;
  line-height: 1;
  color: #ffd166;
}

.gesture-badge em {
  max-width: 220px;
  color: rgba(243,240,232,0.62);
  font-size: 11px;
  font-style: normal;
  line-height: 1.35;
}

.gesture-ring {
  display: none;
  position: absolute;
  left: 50%;
  top: 50%;
  width: min(68vw, 620px);
  aspect-ratio: 1;
  transform: translate(-50%, -44%);
  border-radius: 50%;
  pointer-events: none;
  border: 3px solid rgba(255, 209, 102, 0.5);
  box-shadow:
    inset 0 0 28px rgba(36, 231, 120, 0.28),
    0 0 0 6px rgba(139, 211, 221, 0.16),
    0 0 42px rgba(255, 209, 102, 0.26);
  z-index: 3;
  animation: ringPulse 1.5s ease-in-out infinite;
}

.video-wrap.fx-off #faceCanvas,
.video-wrap.fx-off .effects-layer {
  display: none;
}

.effects-layer {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 4;
}

.fx-pop {
  position: absolute;
  display: grid;
  place-items: center;
  min-width: 28px;
  height: 28px;
  font-size: clamp(18px, 3.2vw, 36px);
  font-weight: 900;
  text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  animation: fxPop 900ms ease-out forwards;
}

.live-gesture-palette {
  position: absolute;
  left: 50%;
  bottom: 76px;
  width: min(760px, calc(100% - 48px));
  transform: translateX(-50%);
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10px;
  z-index: 6;
  justify-content: center;
}

.drum-touch-zone {
  position: absolute;
  right: 12px;
  top: 56px;
  z-index: 8;
  width: 60px;
  height: 60px;
  display: grid;
  place-items: center;
  border: 1px solid var(--stroke);
  border-radius: 16px;
  background: rgba(255,255,255,0.1);
  color: var(--text);
  font-size: 28px;
  backdrop-filter: blur(22px) saturate(1.35);
  box-shadow: 0 12px 28px rgba(0,0,0,0.22);
  pointer-events: none;
  transition: background 140ms ease, border-color 140ms ease, box-shadow 140ms ease, opacity 140ms ease;
}

.drum-touch-zone.armed,
.drum-touch-zone.active {
  border-color: var(--accent);
  background: rgba(255,209,102,0.22);
  box-shadow: 0 0 0 2px rgba(255,209,102,0.22), 0 14px 32px rgba(0,0,0,0.25);
}

.drum-touch-zone.disabled {
  opacity: 0.35;
}

.live-gesture-palette button {
  display: grid;
  place-items: center;
  text-align: center;
  gap: 2px;
  min-height: 66px;
  padding: 8px;
  color: var(--button-text);
  background: var(--button);
  border: 1px solid var(--stroke);
  backdrop-filter: blur(22px) saturate(1.35);
}

.theme-switch {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 8;
  display: inline-flex;
  gap: 2px;
  padding: 3px;
  border: 1px solid var(--stroke);
  border-radius: 999px;
  background: var(--glass-strong);
  backdrop-filter: blur(22px) saturate(1.4);
  box-shadow: 0 10px 24px rgba(0,0,0,0.22);
}

.theme-switch button {
  min-width: 28px;
  width: 28px;
  min-height: 28px;
  height: 28px;
  padding: 0;
  border-radius: 999px;
  border: 0;
  color: var(--button-text);
  background: transparent;
  font-size: 14px;
  line-height: 1;
}

.theme-switch button.active {
  color: #15171b;
  background: var(--accent);
  outline: 0;
}

.live-gesture-palette button.active {
  color: #06251a;
  background: #24e778;
  border-color: rgba(255,255,255,0.5);
  outline: 0;
  box-shadow: 0 0 28px rgba(36, 231, 120, 0.42);
}

.live-gesture-palette strong {
  font-size: clamp(16px, 2.1vw, 28px);
  line-height: 1;
}

.live-gesture-palette span {
  font-size: 13px;
  opacity: 0.72;
}

.beat-meter {
  position: absolute;
  left: 50%;
  bottom: 42px;
  width: min(760px, calc(100% - 48px));
  transform: translateX(-50%);
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 6px;
  z-index: 6;
}

.beat-meter i {
  height: 5px;
  border-radius: 999px;
  background: rgba(255,255,255,0.22);
}

.beat-meter i.active {
  background: #ffd166;
  box-shadow: 0 0 18px rgba(255, 209, 102, 0.82);
}

.lyric-line {
  margin: 0;
  font-size: clamp(18px, 2.2vw, 28px);
  line-height: 1.18;
  font-weight: 700;
}

.lyric-meta {
  margin-top: 8px;
  display: flex;
  justify-content: center;
  gap: 12px;
  color: var(--muted);
}

.lyric-chord {
  color: var(--accent-2);
  font-weight: 800;
}

.controls {
  display: flex;
  flex-direction: column;
  gap: 14px;
  min-height: 0;
  overflow: auto;
  padding-right: 4px;
}

.controls::-webkit-scrollbar {
  width: 8px;
}

.controls::-webkit-scrollbar-track {
  background: transparent;
}

.controls::-webkit-scrollbar-thumb {
  border-radius: 999px;
  background: rgba(255,255,255,0.18);
}

header p {
  margin: 0 0 4px;
  color: var(--accent-2);
  font-size: 12px;
}

header {
  position: sticky;
  top: 0;
  z-index: 2;
  padding: 2px 0 4px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.08), rgba(255,255,255,0));
}

h1, h2 {
  margin: 0;
  letter-spacing: 0;
}

h1 { font-size: 26px; }
h2 { font-size: 15px; }

.panel {
  display: grid;
  gap: 12px;
  padding: 14px;
  border: 1px solid var(--stroke);
  border-radius: 14px;
  background: var(--glass);
  box-shadow: 0 14px 34px rgba(0,0,0,0.16), inset 0 1px 0 rgba(255,255,255,0.18);
  backdrop-filter: blur(32px) saturate(1.45);
}

.panel.compact p {
  margin: 0;
  color: rgba(243,240,232,0.72);
  line-height: 1.5;
  font-size: 13px;
}

/* Hide the chord chart UI for now; HTML and JS are intentionally kept. */
.chord-panel {
  display: none;
}

.binding-panel {
  gap: 10px;
}

.gesture-binding-list {
  display: grid;
  gap: 8px;
}

.binding-search {
  width: 100%;
  min-height: 36px;
  padding: 8px 10px;
  color: var(--text);
  background: var(--glass-strong);
  border: 1px solid var(--stroke);
  border-radius: 10px;
  backdrop-filter: blur(18px) saturate(1.25);
}

.gesture-binding-row {
  display: grid;
  grid-template-columns: 62px minmax(0, 1fr) 34px;
  align-items: center;
  gap: 10px;
  min-height: 48px;
  padding: 8px 10px;
  border: 1px solid var(--stroke);
  border-radius: 12px;
  background: var(--glass);
  backdrop-filter: blur(22px) saturate(1.35);
}

.gesture-binding-row span {
  display: inline-flex;
  align-items: baseline;
  gap: 3px;
  color: var(--text);
}

.gesture-binding-row strong {
  font-size: 22px;
  line-height: 1;
  color: var(--accent);
}

.gesture-binding-row em {
  color: var(--muted);
  font-size: 13px;
  font-style: normal;
  font-weight: 800;
}

.gesture-binding-select {
  width: 100%;
  min-width: 0;
  color: var(--text);
  background: var(--glass-strong);
  border: 1px solid var(--stroke);
  border-radius: 9px;
  backdrop-filter: blur(18px) saturate(1.25);
}

.finger-upload-btn {
  position: relative;
  min-height: 34px;
  width: 34px;
  padding: 0;
  display: grid;
  place-items: center;
  color: var(--button-text);
  background: var(--button);
  border: 1px solid var(--stroke);
  border-radius: 9px;
  font-size: 15px;
}

.finger-upload-btn.has-upload::after {
  content: "";
  position: absolute;
  right: 4px;
  top: 4px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #40e070;
  box-shadow: 0 0 8px rgba(64,224,112,0.75);
}

.finger-upload-input {
  display: none;
}

.row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.row.single {
  grid-template-columns: 1fr;
}

button {
  border: 0;
  border-radius: 9px;
  min-height: 42px;
  padding: 0 12px;
  color: #15171b;
  background: var(--accent);
  cursor: pointer;
  font-weight: 800;
  transition: transform 140ms ease, box-shadow 140ms ease, background 140ms ease;
}

button:hover:not(:disabled) {
  transform: translateY(-1px);
}

button.secondary {
  color: var(--button-text);
  background: var(--button);
  border: 1px solid var(--stroke);
  backdrop-filter: blur(18px) saturate(1.3);
}

button.active {
  outline: 2px solid var(--accent-2);
}

#cameraBtn.active {
  color: #15171b;
  background: var(--accent);
  border-color: rgba(255,255,255,0.45);
}

button:disabled {
  cursor: not-allowed;
  opacity: 0.45;
}

label {
  display: grid;
  grid-template-columns: auto minmax(0,1fr) 36px;
  align-items: center;
  gap: 10px;
  color: var(--muted);
}

.toggle-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.toggle-list label {
  grid-template-columns: 18px minmax(0, 1fr);
  min-height: 34px;
  padding: 7px 8px;
  border-radius: 7px;
  background: var(--glass);
  font-size: 13px;
}

input[type="range"] { width: 100%; }
select, textarea {
  min-height: 34px;
  border: 1px solid var(--stroke);
  border-radius: 9px;
  color: var(--text);
  background: var(--glass-strong);
  backdrop-filter: blur(14px);
}

.rhythm-modules {
  display: grid;
  gap: 10px;
}

.rhythm-card {
  display: grid;
  gap: 10px;
  padding: 12px;
  border: 1px solid var(--stroke);
  border-radius: 12px;
  background: var(--glass-strong);
  backdrop-filter: blur(24px) saturate(1.35);
}

.rhythm-card h3 {
  margin: 0;
  font-size: 13px;
  letter-spacing: 0;
}

.stacked-label {
  display: grid;
  grid-template-columns: 1fr;
  align-items: stretch;
  gap: 6px;
  color: var(--muted);
  font-size: 12px;
}

.toggle-row {
  grid-template-columns: 18px minmax(0, 1fr);
  min-height: 34px;
  padding: 7px 8px;
  border-radius: 9px;
  background: var(--glass);
  font-size: 13px;
}

textarea {
  width: 100%;
  resize: vertical;
  padding: 9px 10px;
  line-height: 1.45;
}

.chord-picker {
  display: grid;
  gap: 7px;
  padding: 9px;
  border: 1px solid var(--stroke);
  border-radius: 12px;
  background: var(--glass);
  backdrop-filter: blur(22px) saturate(1.35);
}

.chord-picker-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  color: var(--muted);
  font-size: 12px;
}

.clear-progression-btn {
  width: 28px;
  min-width: 28px;
  height: 28px;
  min-height: 28px;
  padding: 0;
  border-radius: 999px;
  color: var(--button-text);
  background: var(--button);
  border: 1px solid var(--stroke);
}

.quick-chord-rows {
  display: grid;
  gap: 5px;
}

.quick-chord-row {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}

.quick-chord-btn {
  display: grid;
  place-items: center;
  gap: 1px;
  min-height: 28px;
  padding: 0 8px;
  border-radius: 8px;
  color: var(--button-text);
  background: var(--button);
  border: 1px solid var(--stroke);
  font-size: 12px;
  font-weight: 800;
  backdrop-filter: blur(16px) saturate(1.25);
}

.quick-chord-btn span,
.quick-chord-btn small {
  line-height: 1.05;
}

.quick-chord-btn span {
  font-size: 13px;
}

.quick-chord-btn small {
  color: var(--muted);
  font-size: 10px;
  font-weight: 700;
}

.quick-chord-btn:hover {
  border-color: var(--accent-2);
  background: var(--glass-strong);
}

.preset-label select {
  width: 100%;
}

.progression-strip {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 2px;
}

.progression-strip span {
  flex: 0 0 auto;
  min-width: 72px;
  display: grid;
  gap: 2px;
  padding: 8px 10px;
  border-radius: 7px;
  background: var(--glass);
  border: 1px solid var(--stroke);
}

.progression-strip span.active {
  border-color: var(--accent-2);
  background: rgba(139, 211, 221, 0.16);
}

.progression-strip strong,
.progression-strip em,
.progression-strip small {
  font-style: normal;
  line-height: 1.15;
}

.progression-strip em,
.progression-strip small {
  color: var(--muted);
  font-size: 11px;
}
input[type="file"] {
  width: 100%;
  color: var(--muted);
}

audio {
  width: 100%;
  height: 34px;
}

.hint {
  margin: 0;
  color: var(--muted);
  font-size: 12px;
  line-height: 1.45;
}

.segmented {
  display: grid;
  gap: 8px;
}

.custom-melody-section {
  display: none;
  margin-top: 8px;
}

.custom-string-grid,
.custom-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.custom-string-grid {
  margin: 8px 0;
}

.custom-string-btn {
  width: 54px;
  height: 54px;
  min-height: 54px;
  padding: 0;
  display: grid;
  place-items: center;
  gap: 0;
  border: 1px solid var(--stroke);
  border-radius: 12px;
  color: var(--text);
  background: var(--glass-strong);
  backdrop-filter: blur(20px) saturate(1.4);
}

.custom-string-btn span {
  font-size: 20px;
  font-weight: 900;
  line-height: 1;
}

.custom-string-btn small {
  color: var(--muted);
  font-size: 11px;
  font-weight: 700;
}

.custom-string-grid.editing .custom-string-btn {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px rgba(255,209,102,0.2);
}

.custom-string-btn.flash {
  color: #15171b;
  background: var(--accent);
  box-shadow: 0 0 24px rgba(255,209,102,0.42);
}

.custom-string-btn.flash small {
  color: rgba(21,23,27,0.72);
}

.custom-progression-row {
  display: grid;
  gap: 8px;
  margin: 8px 0;
}

.custom-progression-tags {
  min-height: 38px;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px;
  padding: 8px;
  border: 1px solid var(--stroke);
  border-radius: 10px;
  background: var(--glass-strong);
  color: var(--muted);
}

.custom-tag {
  min-width: 34px;
  min-height: 28px;
  display: inline-grid;
  grid-auto-flow: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  padding: 4px 8px;
  border-radius: 999px;
  color: var(--text);
  background: var(--glass);
  border: 1px solid var(--stroke);
  font-weight: 900;
}

.custom-tag small {
  color: var(--accent-2);
  font-size: 10px;
}

.custom-root-hint {
  color: var(--accent-2);
  font-size: 12px;
  font-weight: 800;
}

@media (max-width: 860px) {
  body {
    overflow: auto;
  }

  .app {
    height: auto;
    min-height: 100vh;
    grid-template-columns: 1fr;
    padding: 12px;
    overflow: visible;
  }

  .video-wrap, video {
    height: clamp(260px, 48vh, 420px);
    min-height: 0;
  }

  .gesture-badge {
    top: 10px;
    left: 10px;
  }

  .gesture-badge strong {
    font-size: 34px;
  }

  .gesture-ring {
    width: min(92vw, 430px);
  }

  .live-gesture-palette {
    bottom: 46px;
    width: calc(100% - 24px);
    gap: 5px;
  }

  .live-gesture-palette button {
    min-height: 48px;
    padding: 6px 4px;
  }

  .beat-meter {
    bottom: 24px;
    width: calc(100% - 24px);
  }

  .controls {
    overflow: visible;
    padding-right: 0;
  }

  .controls {
    padding-bottom: 16px;
  }
}

@keyframes ringPulse {
  0%, 100% { opacity: 0.75; transform: translate(-50%, -44%) scale(0.98); }
  50% { opacity: 1; transform: translate(-50%, -44%) scale(1.02); }
}

@keyframes fxPop {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.45) rotate(0);
  }
  16% { opacity: 1; }
  100% {
    opacity: 0;
    transform: translate(calc(-50% + var(--dx)), calc(-50% + var(--dy))) scale(1.25) rotate(var(--rot));
  }
}
